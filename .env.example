# ──────────────────────────────────────────────────────────────
# Max Agent Bureau — environment variables
# Copy to `.env.local` for local dev. Set the same keys in Vercel.
# NEVER commit real values.
# ──────────────────────────────────────────────────────────────

# Neon Postgres (EU region — Frankfurt — required for DSGVO).
# Get from the Neon dashboard -> Connection string (pooled).
DATABASE_URL="postgresql://USER:PASSWORD@HOST.eu-central-1.aws.neon.tech/DBNAME?sslmode=require"

# ──────────────────────────────────────────────────────────────
# Auth.js / NextAuth (Auth-1B) — required for login to function.
# AUTH_SECRET: generate with `openssl rand -base64 32` — never reuse across envs.
# NEXTAUTH_URL: full base URL of this deployment.
# NEVER commit real values. NEVER prefix with NEXT_PUBLIC_.
# ──────────────────────────────────────────────────────────────
AUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Telegram lead notifications (OPTIONAL — feature-flagged).
# If both are empty, the page still works; leads persist, notification is skipped.
# Create a bot with @BotFather to get the token, then get your chat id.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# Public site URL (used for OG/canonical). e.g. https://agents.maxpromo.digital
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ──────────────────────────────────────────────────────────────
# AI provider — Anthropic is the DEFAULT (claude-sonnet-4-6).
# OPTIONAL: only needed to use the AI Lab / /api/ai routes. The app builds and
# the dashboard renders WITHOUT these. AI routes return 503 ai_not_configured.
# NEVER prefix AI keys with NEXT_PUBLIC_ — they are server-only secrets.
# ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=""
AI_PROVIDER="anthropic"
AI_MODEL="claude-sonnet-4-6"
AI_TEMPERATURE="0.3"

# Optional: switch to OpenAI by setting AI_PROVIDER=openai + this key.
# OPENAI_API_KEY=""

# ──────────────────────────────────────────────────────────────
# Rate limiting (Auth-4) — Upstash Redis.
# REQUIRED in production for /api/leads, /api/ai/generate,
# /api/approvals/[id], and login attempts.
# If absent, an in-memory fallback is used (resets on deploy —
# acceptable for local dev only).
# Get from Upstash console -> REST API.
# NEVER commit real values. NEVER prefix with NEXT_PUBLIC_.
# ──────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL="https://YOUR-DB.upstash.io"
UPSTASH_REDIS_REST_TOKEN=""
