# ──────────────────────────────────────────────────────────────
# Max Agent Bureau — environment variables (Sprint 1)
# Copy to `.env.local` for local dev. Set the same keys in Vercel.
# NEVER commit real values.
# ──────────────────────────────────────────────────────────────

# Neon Postgres (EU region — Frankfurt — required for DSGVO).
# Get from the Neon dashboard -> Connection string (pooled).
DATABASE_URL="postgresql://USER:PASSWORD@HOST.eu-central-1.aws.neon.tech/DBNAME?sslmode=require"

# Telegram lead notifications (OPTIONAL — feature-flagged).
# If both are empty, the page still works; leads persist, notification is skipped.
# Create a bot with @BotFather to get the token, then get your chat id.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# Public site URL (used for OG/canonical). e.g. https://agents.maxpromo.digital
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ──────────────────────────────────────────────────────────────
# AI provider (Sprint 6A) — OpenAI is the DEFAULT. Anthropic optional/premium later.
# OPTIONAL: only needed to use the AI Lab / /api/ai routes. The app builds and the
# dashboard renders WITHOUT these. AI routes return "ai_not_configured" if absent.
# NEVER prefix AI keys with NEXT_PUBLIC_ — they are server-only secrets.
# ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=""
AI_PROVIDER="openai"
AI_MODEL="gpt-4.1-mini"
AI_TEMPERATURE="0.3"

# Optional future (premium/complex reasoning only — not implemented yet):
# ANTHROPIC_API_KEY=""
# ANTHROPIC_MODEL="claude-sonnet-4-5"
